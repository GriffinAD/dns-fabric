{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kea-fabric.dev/specs/dashboard/layout.schema.json",
  "title": "DashboardLayout",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "tiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "pluginId", "hostControl", "displayMode"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "pluginId": {
            "type": "string",
            "minLength": 1
          },
          "hostControl": {
            "type": "string",
            "enum": ["single-panel", "tab-control", "vertical-stack", "split-grid"]
          },
          "displayMode": {
            "type": "string",
            "enum": ["compact", "full"]
          },
          "region": {
            "type": "string",
            "description": "Optional host region key (e.g. primary-grid, status-zone)"
          },
          "grid": {
            "type": "object",
            "additionalProperties": false,
            "description": "Optional 12-column grid placement (Phase C editor). Servers should reject layouts when col + colSpan > 12.",
            "required": ["col", "row", "colSpan", "rowSpan"],
            "properties": {
              "col": {
                "type": "integer",
                "minimum": 0,
                "maximum": 11
              },
              "row": {
                "type": "integer",
                "minimum": 0
              },
              "colSpan": {
                "type": "integer",
                "minimum": 1,
                "maximum": 12
              },
              "rowSpan": {
                "type": "integer",
                "minimum": 1,
                "maximum": 12,
                "description": "Tile height in grid rows; dashboard may have unlimited rows."
              }
            }
          },
          "options": {
            "type": "object",
            "additionalProperties": false,
            "description": "Per-tile display options (performance plugin and shared toggles).",
            "properties": {
              "cpu_total": {
                "type": "boolean",
                "description": "When true, CPU is shown as a single aggregate gauge."
              },
              "network_by_adapter": {
                "type": "boolean",
                "description": "When true, network I/O is split per adapter."
              },
              "disk_by_volume": {
                "type": "boolean",
                "description": "When true, disk usage is split per volume/mount."
              },
              "display_style": {
                "type": "string",
                "enum": ["gauge", "percent_only"]
              },
              "perf_max_cols": {
                "type": "integer",
                "minimum": 1,
                "maximum": 12,
                "description": "Max dashboard columns for a performance tile; extra gauges wrap inside the tile."
              }
            }
          }
        }
      }
    }
  },
  "required": ["version", "tiles"]
}
