{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kea-fabric.dev/specs/dashboard/layout.schema.json",
  "title": "DashboardLayout",
  "$defs": {
    "gridPlacement": {
      "type": "object",
      "additionalProperties": false,
      "description": "Root and auto-wrap group tiles: 0–19 col, col+colSpan ≤ 20. Group with Auto wrap off may use a wider col strip (max ~10000); API and UI validate per context.",
      "required": ["col", "row", "colSpan", "rowSpan"],
      "properties": {
        "col": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "row": { "type": "integer", "minimum": 0 },
        "colSpan": { "type": "integer", "minimum": 1, "maximum": 20 },
        "rowSpan": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12,
          "description": "Tile height in grid rows (capped for validation; dashboard rows are unbounded in the UI packer)."
        }
      }
    },
    "groupHostControl": {
      "type": "string",
      "enum": ["panel", "tab-control", "vertical-stack", "split-grid"],
      "description": "Container chrome on DashboardGroup (ADR-0054). Omitted means panel."
    },
    "groupHostState": {
      "type": "object",
      "additionalProperties": false,
      "description": "Tab container state (ADR-0054).",
      "properties": {
        "activeChildId": {
          "type": "string",
          "minLength": 1,
          "description": "Active tab child id; defaults to first child when omitted."
        },
        "collapsedChildIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Collapsed section ids for vertical-stack groups."
        }
      }
    },
    "tabLabel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Tab strip label when parent group has hostControl tab-control."
    },
    "tileOptions": {
      "type": "object",
      "additionalProperties": false,
      "description": "Per-tile display options (performance plugin and shared toggles).",
      "properties": {
        "cpu_total": { "type": "boolean" },
        "network_by_adapter": { "type": "boolean" },
        "disk_by_volume": { "type": "boolean" },
        "display_style": { "type": "string", "enum": ["gauge", "percent_only"] },
        "gauge_gradient_mode": { "type": "string", "enum": ["smooth", "banded"] },
        "perf_max_cols": { "type": "integer", "minimum": 1, "maximum": 20 }
      }
    },
    "dashboardTile": {
      "type": "object",
      "additionalProperties": false,
      "description": "A plugin tile (v1 root, v2 root with optional kind, or v2 group child). Inner group children omit kind.",
      "required": ["id", "pluginId", "hostControl", "displayMode"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "pluginId": { "type": "string", "minLength": 1 },
        "hostControl": {
          "type": "string",
          "enum": ["single-panel", "tab-control", "vertical-stack", "split-grid"]
        },
        "displayMode": { "type": "string", "enum": ["compact", "full"] },
        "region": { "type": "string" },
        "rowPanel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "v1 only; optional row panel id for migration. v2 uses groups instead."
        },
        "kind": {
          "type": "string",
          "enum": ["tile"],
          "description": "v2 root tiles should set kind to 'tile' (optional in some clients)."
        },
        "grid": { "$ref": "#/$defs/gridPlacement" },
        "options": { "$ref": "#/$defs/tileOptions" },
        "tabLabel": { "$ref": "#/$defs/tabLabel" }
      }
    },
    "dashboardGroup": {
      "type": "object",
      "additionalProperties": false,
      "description": "Container on the root 20-column grid; inner tiles use the same column rules inside the group.",
      "required": ["kind", "id", "children"],
      "properties": {
        "kind": { "const": "group" },
        "id": { "type": "string", "minLength": 1 },
        "showBorder": {
          "type": "boolean",
          "description": "When true, draw a border on the group and hide inner tile card chrome. Default true when omitted in clients."
        },
        "innerWrap": {
          "type": "boolean",
          "description": "When true, child tiles flow in array order and wrap to a new row when a row is full, with col/row repacked on save. When false or omitted, children use a G-column grid from stored placement (no reflow). Must not be true when hostControl is tab-control."
        },
        "hostControl": { "$ref": "#/$defs/groupHostControl" },
        "hostState": { "$ref": "#/$defs/groupHostState" },
        "grid": { "$ref": "#/$defs/gridPlacement" },
        "tabLabel": { "$ref": "#/$defs/tabLabel" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/dashboardTile" }
        }
      }
    },
    "rootLayoutItem": {
      "oneOf": [
        { "$ref": "#/$defs/dashboardGroup" },
        { "$ref": "#/$defs/dashboardTile" }
      ]
    },
    "dashboardGroupV3": {
      "type": "object",
      "additionalProperties": false,
      "description": "v3 group: children may be tiles or nested groups (max nesting depth 8). innerWrap groups must not contain nested groups; enforce in API (layout_validate.py) and UI.",
      "required": ["kind", "id", "children"],
      "properties": {
        "kind": { "const": "group" },
        "id": { "type": "string", "minLength": 1 },
        "showBorder": { "type": "boolean" },
        "innerWrap": { "type": "boolean" },
        "hostControl": { "$ref": "#/$defs/groupHostControl" },
        "hostState": { "$ref": "#/$defs/groupHostState" },
        "grid": { "$ref": "#/$defs/gridPlacement" },
        "tabLabel": { "$ref": "#/$defs/tabLabel" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/groupChildV3" }
        }
      }
    },
    "groupChildV3": {
      "oneOf": [
        { "$ref": "#/$defs/dashboardTile" },
        { "$ref": "#/$defs/dashboardGroupV3" }
      ],
      "description": "Tile or nested group (v3 only)."
    },
    "rootLayoutItemV3": {
      "oneOf": [
        { "$ref": "#/$defs/dashboardGroupV3" },
        { "$ref": "#/$defs/dashboardTile" }
      ]
    }
  },
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "title": "DashboardLayoutV1",
      "required": ["version", "tiles"],
      "properties": {
        "version": { "type": "integer", "const": 1 },
        "tiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/dashboardTile" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "title": "DashboardLayoutV2",
      "required": ["version", "items"],
      "properties": {
        "version": { "type": "integer", "const": 2 },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/rootLayoutItem" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "title": "DashboardLayoutV3",
      "required": ["version", "items"],
      "properties": {
        "version": { "type": "integer", "const": 3 },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/rootLayoutItemV3" }
        }
      }
    }
  ]
}
