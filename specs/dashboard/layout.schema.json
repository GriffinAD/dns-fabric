{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kea-fabric.dev/specs/dashboard/layout.schema.json",
  "title": "DashboardLayout",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "tiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "pluginId", "hostControl", "displayMode"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "pluginId": {
            "type": "string",
            "minLength": 1
          },
          "hostControl": {
            "type": "string",
            "enum": ["single-panel", "tab-control", "vertical-stack", "split-grid"]
          },
          "displayMode": {
            "type": "string",
            "enum": ["compact", "full"]
          },
          "region": {
            "type": "string",
            "description": "Optional host region key (e.g. primary-grid, status-zone)"
          }
        }
      }
    }
  },
  "required": ["version", "tiles"]
}
