{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kea-fabric.dev/specs/dashboard/layout.schema.json",
  "title": "DashboardLayout",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "tiles": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "required": ["version", "tiles"]
}
